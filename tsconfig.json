{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": { "@/*": ["./client/src/*"] },
    "outDir": "./dist"
  },
  "include": ["client/src/**/*", "vite.config.ts"],
  "exclude": ["node_modules", "dist", "server"]
}
